# Never commit secrets or personal data into this shared distribution.
# This bundle is intentionally credential-free; keep it that way.

# Hermes runtime / secrets (should never be here, but guard anyway)
.env
.env.*
auth.json
*.token
*token*.txt
secrets/
**/secrets/

# Hermes user-owned data (never in a distribution)
memories/
sessions/
state.db*
logs/
*_cache/
local/
checkpoints/
backups/

# Local/editor cruft
.DS_Store
*.swp
*~
__pycache__/
*.pyc
.venv/
venv/
